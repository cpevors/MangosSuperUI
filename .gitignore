# =============================================================================
# MangosSuperUI .gitignore
# =============================================================================

# ----- .NET Build Artifacts -----
bin/
obj/
*.user
*.suo
*.cache
*.dll
*.pdb
*.exe
publish/

# ----- IDE / Editor -----
.vs/
.vscode/
*.swp
*.swo
*~
.idea/

# ----- NuGet -----
*.nupkg
packages/

# ----- Per-Install Configuration -----
# Generated by the setup script — contains DB credentials and local paths
server-config.json

# ----- WoW Client Assets (Blizzard copyrighted — NOT distributable) -----
# These are extracted from the user's own WoW 1.12.1 client via the Extractor tool.
**/wwwroot/icons/
**/wwwroot/models/
**/wwwroot/item_models/
**/wwwroot/minimap/

# Keep the directories in the repo with .gitkeep so the folder structure exists
!**/wwwroot/icons/.gitkeep
!**/wwwroot/models/.gitkeep
!**/wwwroot/item_models/.gitkeep
!**/wwwroot/minimap/.gitkeep

# ----- OS Junk -----
.DS_Store
Thumbs.db
Desktop.ini

# ----- Logs -----
*.log