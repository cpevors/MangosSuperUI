@{
    ViewData["Title"] = "Downloads & Uploads";
}

@section Styles {
    <style>
        .dl-page {
            display: flex;
            height: 100vh;
        }

        .dl-content {
            flex: 1;
            overflow-y: auto;
            padding: 28px 32px;
        }

        .dl-header {
            margin-bottom: 28px;
        }

            .dl-header h1 {
                font-size: 20px;
                font-weight: 700;
                color: var(--text-primary);
                margin: 0 0 4px;
            }

        .dl-header-sub {
            font-size: 13px;
            color: var(--text-muted);
        }

        .dl-section {
            margin-bottom: 32px;
        }

        .dl-section-title {
            font-size: 13px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
            margin-bottom: 14px;
            padding-bottom: 6px;
            border-bottom: 1px solid var(--border-light);
        }

        .dl-cards {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
            gap: 16px;
        }

        .dl-card {
            background: var(--card-bg);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-md);
            padding: 20px;
            transition: border-color 0.15s;
        }

            .dl-card:hover {
                border-color: var(--accent);
            }

        .dl-card-header {
            display: flex;
            align-items: flex-start;
            gap: 14px;
            margin-bottom: 14px;
        }

        .dl-card-icon {
            width: 44px;
            height: 44px;
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

            .dl-card-icon.addon {
                background: rgba(77, 166, 255, 0.12);
                color: var(--accent);
            }

        .dl-card-title {
            font-size: 15px;
            font-weight: 600;
            color: var(--text-primary);
            margin-bottom: 2px;
        }

        .dl-card-version {
            font-size: 11px;
            color: var(--text-muted);
        }

        .dl-card-desc {
            font-size: 13px;
            color: var(--text-secondary);
            line-height: 1.5;
            margin-bottom: 14px;
        }

        .dl-stats {
            display: flex;
            gap: 16px;
            margin-bottom: 16px;
            flex-wrap: wrap;
        }

        .dl-stat {
            font-size: 12px;
            color: var(--text-muted);
        }

        .dl-stat-value {
            font-weight: 600;
            color: var(--text-primary);
        }

        .dl-type-pills {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
            margin-bottom: 16px;
        }

        .dl-type-pill {
            font-size: 11px;
            padding: 2px 8px;
            border-radius: 10px;
            background: var(--surface-alt);
            color: var(--text-muted);
            white-space: nowrap;
        }

            .dl-type-pill .pill-count {
                font-weight: 600;
                color: var(--text-primary);
                margin-left: 3px;
            }

        .dl-actions {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
        }

        .dl-btn {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 7px 14px;
            border-radius: var(--radius-sm);
            font-size: 12px;
            font-weight: 500;
            cursor: pointer;
            border: 1px solid var(--border-light);
            background: var(--surface-alt);
            color: var(--text-primary);
            transition: all 0.15s;
        }

            .dl-btn:hover {
                border-color: var(--accent);
                background: rgba(77, 166, 255, 0.08);
            }

            .dl-btn.primary {
                background: var(--accent);
                color: #fff;
                border-color: var(--accent);
            }

                .dl-btn.primary:hover {
                    background: var(--accent-hover);
                }

            .dl-btn i {
                font-size: 11px;
            }

        .dl-install-steps {
            margin-top: 14px;
            padding-top: 14px;
            border-top: 1px solid var(--border-light);
        }

        .dl-install-toggle, .dl-commands-toggle {
            font-size: 12px;
            color: var(--accent);
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 4px;
        }

            .dl-install-toggle:hover, .dl-commands-toggle:hover {
                text-decoration: underline;
            }

        .dl-install-body, .dl-commands-body {
            display: none;
            margin-top: 10px;
        }

            .dl-install-body.open, .dl-commands-body.open {
                display: block;
            }

        .dl-step {
            display: flex;
            gap: 10px;
            margin-bottom: 10px;
            font-size: 12px;
            color: var(--text-secondary);
            line-height: 1.5;
        }

        .dl-step-num {
            width: 20px;
            height: 20px;
            border-radius: 50%;
            background: var(--surface-alt);
            color: var(--accent);
            font-weight: 600;
            font-size: 11px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
            margin-top: 1px;
        }

        .dl-step code {
            background: var(--surface-alt);
            padding: 1px 5px;
            border-radius: 3px;
            font-size: 11px;
            color: var(--text-primary);
        }

        .dl-commands {
            margin-top: 14px;
            padding-top: 14px;
            border-top: 1px solid var(--border-light);
        }

        .dl-cmd-row {
            display: flex;
            gap: 10px;
            margin-bottom: 6px;
            font-size: 12px;
        }

        .dl-cmd-name {
            font-family: monospace;
            color: var(--accent);
            white-space: nowrap;
            min-width: 160px;
        }

        .dl-cmd-desc {
            color: var(--text-muted);
        }

        .dl-placeholder {
            padding: 24px;
            text-align: center;
            color: var(--text-muted);
            font-size: 13px;
            background: var(--card-bg);
            border: 1px dashed var(--border-light);
            border-radius: var(--radius-md);
        }

            .dl-placeholder i {
                font-size: 22px;
                display: block;
                margin-bottom: 8px;
                opacity: 0.4;
            }

        .dl-readme {
            font-size: 13px;
            color: var(--text-secondary);
            line-height: 1.6;
            margin-bottom: 14px;
        }

        .dl-readme-h {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-primary);
            margin: 12px 0 4px;
        }

            .dl-readme-h:first-child {
                margin-top: 0;
            }

        .dl-readme-p {
            margin: 0 0 8px;
        }

        .dl-readme-list {
            margin: 0 0 8px;
            padding-left: 18px;
        }

            .dl-readme-list li {
                margin-bottom: 3px;
            }

        .dl-readme-code {
            background: var(--surface-alt);
            padding: 1px 5px;
            border-radius: 3px;
            font-size: 12px;
            font-family: monospace;
            color: var(--text-primary);
        }
    </style>
}

<div class="dl-page">
    @await Html.PartialAsync("_Sidebar")

    <div class="dl-content">
        <div class="dl-header">
            <h1><i class="fa-solid fa-arrow-down-to-line" style="color:var(--accent);margin-right:8px;font-size:18px;"></i> Downloads & Uploads</h1>
            <div class="dl-header-sub">WoW client addons, catalog exports, and file uploads for your server.</div>
        </div>

        <!-- WoW Addons -->
        <div class="dl-section">
            <div class="dl-section-title">WoW Addons</div>
            <div class="dl-cards" id="addonCards">
                <div class="text-center p-4"><i class="fa-solid fa-spinner fa-spin"></i> Loading addons...</div>
            </div>
        </div>

        <!-- Uploads (future) -->
        <div class="dl-section">
            <div class="dl-section-title">Uploads</div>
            <div class="dl-placeholder">
                <i class="fa-solid fa-cloud-arrow-up"></i>
                Upload functionality coming soon — import patches, custom DBC overrides, and more.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/downloads.js" asp-append-version="true"></script>
}
