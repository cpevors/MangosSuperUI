@{
    ViewData["Title"] = "Live Logs";
}

<div class="app-shell">
    <partial name="_Sidebar" />

    <div class="main-content">
        <div class="content-header">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h1>Live Logs</h1>
                    <p>Real-time server log file streaming</p>
                </div>
                <div class="d-flex gap-2 align-items-center">
                    <label class="ll-toggle" title="Auto-scroll to bottom on new lines">
                        <input type="checkbox" id="autoScroll" checked />
                        <span>Auto-scroll</span>
                    </label>
                    <button class="btn-outline-subtle" id="btnPause">
                        <i class="fa-solid fa-pause"></i> Pause
                    </button>
                    <button class="btn-outline-subtle" id="btnClear">
                        <i class="fa-solid fa-trash-can"></i> Clear
                    </button>
                </div>
            </div>
        </div>

        <div class="content-body" style="display: flex; flex-direction: column; overflow: hidden;">
            <!-- Log file selector cards -->
            <div class="ll-files" id="logFiles">
                <div class="text-center text-muted" style="padding: 20px;">
                    <i class="fa-solid fa-spinner fa-spin"></i> Connecting...
                </div>
            </div>

            <!-- Search / filter -->
            <div class="ll-toolbar">
                <div class="ll-search-wrap">
                    <i class="fa-solid fa-magnifying-glass ll-search-icon"></i>
                    <input type="text" class="form-input ll-search-input" id="llSearch"
                           placeholder="Filter lines (highlight matches)..." autocomplete="off" spellcheck="false" />
                </div>
                <div class="ll-status" id="llStatus">
                    <span class="ll-status-dot offline"></span>
                    <span id="llStatusText">Disconnected</span>
                </div>
                <div class="ll-line-count" id="llLineCount">0 lines</div>
            </div>

            <!-- Log output -->
            <div class="ll-output" id="llOutput"></div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* File selector */
        .ll-files {
            display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 12px; flex-shrink: 0;
        }
        .ll-file {
            padding: 6px 14px; border-radius: var(--radius-md); font-size: 12px; font-weight: 500;
            color: var(--text-secondary); cursor: pointer; border: 1px solid var(--border-light);
            background: var(--bg-card); transition: all var(--transition-fast); display: flex;
            align-items: center; gap: 6px; white-space: nowrap;
        }
        .ll-file:hover { border-color: var(--accent); color: var(--text-primary); }
        .ll-file.active { background: var(--accent); border-color: var(--accent); color: #fff; }
        .ll-file.empty { opacity: 0.5; }
        .ll-file-size { font-size: 10px; opacity: 0.7; }
        .ll-file.active .ll-file-size { opacity: 0.8; }

        /* Toolbar */
        .ll-toolbar {
            display: flex; align-items: center; gap: 12px; margin-bottom: 8px; flex-shrink: 0;
        }
        .ll-search-wrap { position: relative; flex: 1; }
        .ll-search-icon { position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted); font-size: 13px; pointer-events: none; }
        .ll-search-input { padding-left: 36px !important; font-size: 13px; }

        .ll-status { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--text-secondary); white-space: nowrap; }
        .ll-status-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
        .ll-status-dot.online { background: var(--status-online); box-shadow: 0 0 6px rgba(34,197,94,0.4); }
        .ll-status-dot.offline { background: var(--status-offline); }
        .ll-status-dot.paused { background: var(--status-warning); }

        .ll-line-count { font-size: 11px; color: var(--text-muted); white-space: nowrap; }

        .ll-toggle { display: flex; align-items: center; gap: 5px; font-size: 12px; color: var(--text-secondary); cursor: pointer; white-space: nowrap; }

        /* Output */
        .ll-output {
            flex: 1; min-height: 0; overflow-y: auto;
            font-family: 'Consolas', 'Courier New', monospace; font-size: 12px; line-height: 1.6;
            background: #0f1319; color: #c8d0da; padding: 12px 16px;
            border-radius: var(--radius-md); white-space: pre-wrap; word-break: break-all;
        }

        /* Line styling */
        .ll-line { padding: 0 4px; border-radius: 2px; }
        .ll-line:hover { background: rgba(255,255,255,0.03); }
        .ll-line-error { color: #f7768e; }
        .ll-line-warning { color: #e0af68; }
        .ll-line-info { color: #c8d0da; }
        .ll-line-chat { color: #bb9af7; }
        .ll-line-time { color: #565f89; }
        .ll-hl { background: rgba(245,158,11,0.3); border-radius: 2px; padding: 0 1px; }
        .ll-line-hidden { display: none; }

        /* Paused overlay */
        .ll-paused-badge {
            position: absolute; top: 12px; right: 28px;
            background: var(--status-warning); color: #000; font-weight: 700;
            font-size: 11px; padding: 3px 10px; border-radius: 4px;
            text-transform: uppercase; letter-spacing: 0.04em; z-index: 10;
        }
    </style>
}

@section Scripts {
    <script src="~/js/livelogs.js" asp-append-version="true"></script>
}
