@{
    ViewData["Title"] = "Realm";
}

<div class="app-shell">
    <partial name="_Sidebar" />

    <div class="main-content">
        <div class="content-header">
            <h1>Realm</h1>
            <p>View and configure realm settings</p>
        </div>

        <div class="content-body">
            <!-- Server Stats -->
            <div class="realm-stats" id="realmStats">
                <div class="realm-stat-card">
                    <i class="fa-solid fa-users" style="color: var(--status-online);"></i>
                    <div>
                        <div class="realm-stat-value" id="statOnlinePlayers">—</div>
                        <div class="realm-stat-label">Players Online</div>
                    </div>
                </div>
                <div class="realm-stat-card">
                    <i class="fa-solid fa-circle-user" style="color: var(--accent);"></i>
                    <div>
                        <div class="realm-stat-value" id="statOnlineAccounts">—</div>
                        <div class="realm-stat-label">Accounts Online</div>
                    </div>
                </div>
                <div class="realm-stat-card">
                    <i class="fa-solid fa-id-badge" style="color: var(--text-secondary);"></i>
                    <div>
                        <div class="realm-stat-value" id="statTotalAccounts">—</div>
                        <div class="realm-stat-label">Total Accounts</div>
                    </div>
                </div>
            </div>

            <!-- Realm Cards -->
            <div id="realmList">
                <div class="text-center text-muted" style="padding: 60px;">
                    <i class="fa-solid fa-spinner fa-spin" style="font-size: 24px;"></i>
                    <div style="margin-top: 12px;">Loading realm data...</div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Stats row */
        .realm-stats {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
        }
        .realm-stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            padding: 16px 20px;
            display: flex;
            align-items: center;
            gap: 14px;
            flex: 1;
            box-shadow: var(--shadow-sm);
        }
        .realm-stat-card i { font-size: 22px; }
        .realm-stat-value {
            font-size: 22px;
            font-weight: 700;
            color: var(--text-primary);
            line-height: 1;
        }
        .realm-stat-label {
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-muted);
            margin-top: 2px;
        }

        /* Realm card */
        .realm-card {
            background: var(--bg-card);
            border: 1px solid var(--border-light);
            border-radius: var(--radius-lg);
            box-shadow: var(--shadow-sm);
            margin-bottom: 16px;
        }
        .realm-card-header {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-light);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }
        .realm-card-title {
            font-size: 17px;
            font-weight: 700;
            color: var(--text-primary);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .realm-card-body { padding: 20px; }

        /* Realm field grid */
        .realm-fields {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 16px;
        }
        .realm-field label {
            font-size: 11.5px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            color: var(--text-muted);
            margin-bottom: 4px;
            display: block;
        }
        .realm-field .form-input {
            font-size: 13.5px;
        }
        .realm-field-readonly {
            font-size: 13.5px;
            font-weight: 500;
            color: var(--text-primary);
            padding: 8px 0;
        }

        /* Status indicator */
        .realm-status {
            font-size: 11px;
            font-weight: 600;
            padding: 3px 10px;
            border-radius: 10px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
        }
        .realm-status-online { background: rgba(34,197,94,0.12); color: var(--status-online); }
        .realm-status-offline { background: rgba(148,163,184,0.12); color: var(--text-muted); }

        /* Realm type badge */
        .realm-type-badge {
            font-size: 11px;
            font-weight: 600;
            padding: 2px 8px;
            border-radius: 4px;
            background: rgba(59,130,196,0.12);
            color: var(--accent);
        }

        /* Flag chips */
        .realm-flags {
            display: flex;
            gap: 6px;
            flex-wrap: wrap;
            padding: 8px 0;
        }
        .realm-flag-chip {
            font-size: 10.5px;
            font-weight: 600;
            padding: 2px 8px;
            border-radius: 4px;
            background: var(--bg-card-alt);
            border: 1px solid var(--border-light);
            color: var(--text-secondary);
        }

        /* Action bar */
        .realm-actions {
            padding: 14px 20px;
            border-top: 1px solid var(--border-light);
            display: flex;
            justify-content: flex-end;
            gap: 8px;
        }

        /* Toast */
        .realm-toast {
            position: fixed;
            bottom: 24px;
            right: 24px;
            padding: 12px 20px;
            border-radius: var(--radius-md);
            font-size: 13px;
            font-weight: 600;
            color: #fff;
            z-index: 9999;
            box-shadow: var(--shadow-lg);
            animation: realmToastIn 0.3s ease;
        }
        .realm-toast-success { background: var(--status-online); }
        .realm-toast-error { background: var(--status-error); }
        @@keyframes realmToastIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
    </style>
}

@section Scripts {
    <script src="~/js/realm.js" asp-append-version="true"></script>
}
